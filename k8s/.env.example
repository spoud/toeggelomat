# Copy this file to .env and fill in real values - .env is gitignored so
# these never end up committed. apply.sh reads this file and substitutes
# ${HOSTNAME} / ${OFFICE_IP} placeholders in the manifests before applying.

# Public hostname this app is served on.
HOSTNAME=example.spoud.io

# Office public IP allowed through the AuthorizationPolicy, as a CIDR
# (single IP = /32). Check with: curl ifconfig.me
OFFICE_IP=203.0.113.1/32
